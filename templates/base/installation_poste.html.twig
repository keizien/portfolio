{% extends 'base.html.twig' %}

{% block title %}Installer, déployer et configurer un poste de travail{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="text-center text-primary display-4 fw-bold mb-4">
        <i class="bi bi-pc-display"></i>
        Installer, déployer et configurer un poste de travail
    </h1>

    <p class="text-center text-secondary fs-5 mb-5">
        Sous-compétence du bloc « Gérer le patrimoine informatique ».
    </p>

    <div class="card shadow border-0 p-4">
        <h3 class="fw-bold mb-3 text-primary">Description de ce que j'ai réalisé</h3>

        <p class="fs-5 text-muted">
            Explication
        </p>

        <h4 class="fw-bold mt-4 text-primary">Téléchargements</h4>
        <div class="mt-3">
            <a href="{{ asset('competences/installation_poste/documentation.pdf') }}"
               class="btn btn-primary me-2"
               download>
                <i class="bi bi-file-earmark-text-fill"></i>
                Télécharger la documentation
            </a>

            <a href="{{ asset('competences/installation_poste/diaporama.pdf') }}"
               class="btn btn-success"
               download>
                <i class="bi bi-file-earmark-slides-fill"></i>
                Télécharger le diaporama
            </a>
        </div>

        <a href="{{ path('app_competences') }}" class="btn btn-outline-primary mt-4">
            <i class="bi bi-arrow-left"></i> Retour aux compétences
        </a>
    </div>
</div>
{% endblock %}
