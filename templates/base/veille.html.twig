{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }}Veille Technologique
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sora', sans-serif; background-color: #fff; }

        /* Header Style (Indigo pour la Veille) */
        .pf-page-header {
            padding: 4rem 3rem 3rem;
            border-bottom: 1px solid #e5e7eb;
            background: linear-gradient(to bottom right, #f5f3ff, #ede9fe);
        }

        .pf-page-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-family: 'Space Mono', monospace;
            font-size: 11px;
            color: #4f46e5;
            background: #f5f3ff;
            border: 1px solid #ddd6fe;
            border-radius: 100px;
            padding: 4px 14px;
            margin-bottom: 1.25rem;
        }

        .pf-page-title {
            font-size: clamp(28px, 4vw, 40px);
            font-weight: 700;
            letter-spacing: -1.5px;
            color: #111827;
            margin: 0 0 1rem;
        }

        .pf-page-title em { font-style: normal; color: #6366f1; }

        /* Layout */
        .pf-container { max-width: 1100px; margin: 0 auto; padding: 3rem; }

        /* Grid des Veilles */
        .pf-veille-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2rem;
        }

        .pf-veille-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 20px;
            padding: 2.5rem;
            text-decoration: none;
            display: flex;
            flex-direction: column;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .pf-veille-card::before {
            content: "";
            position: absolute;
            top: 0; left: 0; width: 4px; height: 100%;
            background: #6366f1;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .pf-veille-card:hover {
            border-color: #6366f1;
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(99, 102, 241, 0.1);
        }

        .pf-veille-card:hover::before { opacity: 1; }

        .pf-veille-tag {
            font-family: 'Space Mono', monospace;
            font-size: 11px;
            font-weight: 700;
            color: #6366f1;
            text-transform: uppercase;
            margin-bottom: 1rem;
        }

        .pf-veille-name {
            font-size: 22px;
            font-weight: 700;
            color: #111827;
            margin-bottom: 0.75rem;
            line-height: 1.2;
        }

        .pf-veille-desc {
            font-size: 14px;
            color: #6b7280;
            line-height: 1.6;
            margin-bottom: 2rem;
            flex-grow: 1;
        }

        .pf-veille-link {
            font-size: 13px;
            font-weight: 600;
            color: #6366f1;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .pf-veille-link svg { transition: transform 0.2s; }
        .pf-veille-card:hover .pf-veille-link svg { transform: translateX(5px); }

        /* Back Bar */
        .pf-back-bar { padding: 2rem 3rem; border-top: 1px solid #e5e7eb; margin-top: 2rem; }
        .pf-btn-back { font-size: 13px; font-family: 'Space Mono', monospace; color: #6b7280; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; }
        .pf-btn-back:hover { color: #6366f1; }
    </style>
{% endblock %}

{% block body %}

<div class="pf-page-header">
    <div class="pf-page-badge">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
        </svg>
        Curiosité & Innovation
    </div>
    <h1 class="pf-page-title">Veille <em>Technologique</em></h1>
    <p class="pf-page-sub">Exploration et analyse des évolutions du monde numérique.</p>
</div>

<div class="pf-container">
    
    <div class="pf-veille-grid">
        
        {# Carte SN1 #}
        <a href="{{ path('app_veille_SN1') }}" class="pf-veille-card sn1-card">
            <div class="pf-veille-tag">Veille SN1</div>
            <h3 class="pf-veille-name">La Fusion Nucléaire Contrôlée</h3>
            <p class="pf-veille-desc">
                Analyse des avancées du projet chinois EAST (Tokamak) et des enjeux scientifiques de l'énergie du futur.
            </p>
            <div class="pf-veille-link">
                Accéder au dossier
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
            </div>
        </a>

        {# Carte SN2 #}
        <a href="{{ path('app_veille_SN2') }}" class="pf-veille-card sn2-card">
            <div class="pf-veille-tag">Sujet SN2</div>
            <h3 class="pf-veille-name">Numérique & Santé Mentale</h3>
            <p class="pf-veille-desc">
                Exploration de l'impact de l'IA, de la réalité virtuelle et des objets connectés sur le diagnostic et le soin psychiatrique.
            </p>
            <div class="pf-veille-link">
                Lire la veille
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
            </div>
        </a>

    </div>

</div>

<div class="pf-back-bar">
    <a href="{{ path('app_accueil') }}" class="pf-btn-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        Retour à l'accueil
    </a>
</div>

{% endblock %}