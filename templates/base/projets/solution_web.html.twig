				<line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
			</svg>
			Retour aux projets
		</a>
	</div>

	<script>
		const pfImages = [
"{{ asset('documents/preuves/solution web/addFichiers.png') }}",
"{{ asset('documents/preuves/solution web/addUser.png') }}",
"{{ asset('documents/preuves/solution web/connexion.png') }}",
"{{ asset('documents/preuves/solution web/fichiers.png') }}",
"{{ asset('documents/preuves/solution web/home.png') }}",
"{{ asset('documents/preuves/solution web/inscription.png') }}",
"{{ asset('documents/preuves/solution web/users.png') }}",
];

let pfCurrent = 0;

function openLightbox(index) {
pfCurrent = index;
document.getElementById('pf-lightbox').style.display = 'flex';
document.body.style.overflow = 'hidden';
renderLightbox();
}

function closeLightbox() {
document.getElementById('pf-lightbox').style.display = 'none';
document.body.style.overflow = '';
}

function nextImage() {
pfCurrent = (pfCurrent + 1) % pfImages.length;
renderLightbox();
}

function prevImage() {
pfCurrent = (pfCurrent - 1 + pfImages.length) % pfImages.length;
renderLightbox();
}

function renderLightbox() {
document.getElementById('pf-lb-img').src = pfImages[pfCurrent];
document.getElementById('pf-lb-counter').textContent = (pfCurrent + 1) + ' / ' + pfImages.length;

// Miniatures
const thumbs = document.getElementById('pf-lb-thumbs');
thumbs.innerHTML = '';
pfImages.forEach((src, i) => {
const dot = document.createElement('div');
dot.onclick = () => {
pfCurrent = i;
renderLightbox();
};
dot.style.cssText = `width:8px; height:8px; border-radius:50%; cursor:pointer; transition:background 0.2s; background:${
i === pfCurrent ? '#fff' : 'rgba(255,255,255,0.3)'
}`;
thumbs.appendChild(dot);
});
}

// Fermer en cliquant en dehors de l'image
document.getElementById('pf-lightbox').addEventListener('click', function (e) {
if (e.target === this) 
closeLightbox();

});

// Navigation clavier
document.addEventListener('keydown', function (e) {
if (document.getElementById('pf-lightbox').style.display === 'none') 
return;

if (e.key === 'ArrowRight') 
nextImage();

if (e.key === 'ArrowLeft') 
prevImage();

if (e.key === 'Escape') 
closeLightbox();

});
	</script>

{% endblock %}
