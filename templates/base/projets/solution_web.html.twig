			<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 15px;">

				<div style="padding: 15px; border-left: 3px solid #1D9E75; background: #f9fafb; border-radius: 0 8px 8px 0;">
					<strong style="display: block; font-size: 13px; color: #111827;">Travailler en mode projet</strong>
					<span style="font-size: 12px; color: #6b7280;">Analyser les objectifs et planifier les activités de data-visualisation.</span>
					<div class="pf-comp-block">
						<a href="{{ path('app_travailler_mode_projet') }}" class="pf-btn-comp-highlight">Voir la compétence</a>
					</div>
				</div>

				<div style="padding: 15px; border-left: 3px solid #1D9E75; background: #f9fafb; border-radius: 0 8px 8px 0;">
					<strong style="display: block; font-size: 13px; color: #111827;">Mettre à disposition un service informatique</strong>
					<span style="font-size: 12px; color: #6b7280;">Déployer, tester et accompagner les utilisateurs dans l'appropriation des solutions informatiques.</span>
					<div class="pf-comp-block">
						<a href="{{ path('app_service_info') }}" class="pf-btn-comp-highlight">Voir la compétence</a>
					</div>
				</div>


			</div>
		</div>
	</div>

	<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px;">

		<a href="{{ asset('documents/preuves/solution web/trello.png') }}" target="_blank" style="text-decoration: none; color: inherit;">
			<div class="pf-preuve-card">
				<div style="display: flex; align-items: center; gap: 12px; margin-bottom: 15px;">
					<div style="background: #E6F1FB; padding: 8px; border-radius: 8px;">
						<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="#185FA5" stroke-width="2">
							<polyline points="16 18 22 12 16 6"></polyline>
							<polyline points="8 6 2 12 8 18"></polyline>
						</svg>
					</div>
					<h3 style="margin: 0; font-size: 15px; font-weight: 700;">Travailler en mode projet</h3>
				</div>
				<p style="font-size: 13px; color: #6b7280; margin-bottom: 15px;">Capture d'écran d'un Trello</p>
				<span class="pf-preuve-badge">L01.1 - Code Source</span>
			</div>
		</a>

		{# Déclencheur - remplace ton <a> existant #}
		<div class="pf-preuve-card" onclick="openLightbox(0)" style="cursor: pointer;">
			<div style="display: flex; align-items: center; gap: 12px; margin-bottom: 15px;">
				<div style="background: #E6F1FB; padding: 8px; border-radius: 8px;">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="#185FA5" stroke-width="2">
						<rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
						<line x1="3" y1="9" x2="21" y2="9"></line>
						<line x1="9" y1="21" x2="9" y2="9"></line>
					</svg>
				</div>
				<h3 style="margin: 0; font-size: 15px; font-weight: 700;">Mettre à disposition un service informatique</h3>
			</div>
			<p style="font-size: 13px; color: #6b7280; margin-bottom: 15px;">Captures d'écran du site (7)</p>
			<span class="pf-preuve-badge">L04.1 - Architecture</span>
		</div>

		{# Modale lightbox #}
		<div
			id="pf-lightbox" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.85); z-index:9999; align-items:center; justify-content:center;">

			{# Bouton fermer #}
			<button onclick="closeLightbox()" style="position:absolute; top:20px; right:24px; background:none; border:none; color:#fff; font-size:28px; cursor:pointer; line-height:1;">✕</button>

			{# Compteur #}
			<div id="pf-lb-counter" style="position:absolute; top:22px; left:50%; transform:translateX(-50%); font-family:'Space Mono',monospace; font-size:12px; color:#9ca3af;"></div>

			{# Flèche gauche #}
			<button onclick="prevImage()" style="position:absolute; left:20px; background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); color:#fff; border-radius:8px; width:44px; height:44px; font-size:20px; cursor:pointer; display:flex; align-items:center; justify-content:center;">‹</button>

			{# Image #}
			<img
			id="pf-lb-img" src="" alt="" style="max-height:85vh; max-width:85vw; border-radius:8px; object-fit:contain;">

			{# Flèche droite #}
			<button onclick="nextImage()" style="position:absolute; right:20px; background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); color:#fff; border-radius:8px; width:44px; height:44px; font-size:20px; cursor:pointer; display:flex; align-items:center; justify-content:center;">›</button>

			{# Miniatures #}
			<div id="pf-lb-thumbs" style="position:absolute; bottom:20px; left:50%; transform:translateX(-50%); display:flex; gap:8px;"></div>
		</div>
	</div>

	<div class="pf-back-bar">
		<a href="{{ path('app_projets') }}" class="pf-btn-back">
