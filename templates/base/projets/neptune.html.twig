			<span class="pf-preuve-badge" style="color:#534AB7; background:#EEEDFE; border-color:#CECBF6;">C4 — Mode projet</span>
		</div>

		{# C5 - Mettre à disposition #}
		<div class="pf-preuve-card" onclick="openLightbox(3)">
			<div style="display: flex; align-items: center; gap: 12px; margin-bottom: 15px;">
