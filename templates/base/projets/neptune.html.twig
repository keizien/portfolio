		<div id="pf-lb2-thumbs" style="position:absolute; bottom:20px; left:50%; transform:translateX(-50%); display:flex; gap:8px;"></div>
	</div>

	{# ── Lightbox C5 ── #}
	<div id="pf-lightbox3" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.85); z-index:9999; align-items:center; justify-content:center;">
		<button onclick="closeLightbox(3)" style="position:absolute; top:20px; right:24px; background:none; border:none; color:#fff; font-size:28px; cursor:pointer; line-height:1;">✕</button>
		<div id="pf-lb3-counter" style="position:absolute; top:22px; left:50%; transform:translateX(-50%); font-family:'Space Mono',monospace; font-size:12px; color:#9ca3af;"></div>
		<button onclick="prevImage(3)" style="position:absolute; left:20px; background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); color:#fff; border-radius:8px; width:44px; height:44px; font-size:20px; cursor:pointer; display:flex; align-items:center; justify-content:center;">‹</button>
		<img id="pf-lb3-img" src="" alt="" style="max-height:85vh; max-width:85vw; border-radius:8px; object-fit:contain;">
		<button onclick="nextImage(3)" style="position:absolute; right:20px; background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); color:#fff; border-radius:8px; width:44px; height:44px; font-size:20px; cursor:pointer; display:flex; align-items:center; justify-content:center;">›</button>
		<div id="pf-lb3-thumbs" style="position:absolute; bottom:20px; left:50%; transform:translateX(-50%); display:flex; gap:8px;"></div>
	</div>

	{# ── Grille des preuves ── #}
	<div
		class="pf-preuves-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; padding: 2rem 3rem; border-top: 1px solid #e5e7eb;">

		{# C1 - Gérer le patrimoine #}
		<div class="pf-preuve-card" onclick="openLightbox(1)">
			<div style="display: flex; align-items: center; gap: 12px; margin-bottom: 15px;">
				<div style="background: #E6F1FB; padding: 8px; border-radius: 8px;">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="#185FA5" stroke-width="2">
						<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
					</svg>
				</div>
				<h3 style="margin: 0; font-size: 15px; font-weight: 700;">Développer la présence en ligne</h3>
			</div>
			<p style="font-size: 13px; color: #6b7280; margin-bottom: 15px;">Schéma réseau, sauvegardes NVRAM et TFTP, configuration des équipements.</p>
			<span class="pf-preuve-badge">C3 — La présence en ligne</span>
		</div>

		{# C2 - Répondre aux incidents #}
		<div class="pf-preuve-card" onclick="openLightbox(4)">
			<div style="display: flex; align-items: center; gap: 12px; margin-bottom: 15px;">
				<div style="background: #E6F1FB; pacldding: 8px; border-radius: 8px;">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="#185FA5" stroke-width="2">
						<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
					</svg>
				</div>
				<h3 style="margin: 0; font-size: 15px; font-weight: 700;">Répondre aux incidents</h3>
			</div>
			<p style="font-size: 13px; color: #6b7280; margin-bottom: 15px;">Tickets GLPI.</p>
			<span class="pf-preuve-badge">C2 — Répondre aux incidents</span>
		</div>

		{# C4 - Travailler en mode projet #}
		<div class="pf-preuve-card" onclick="openLightbox(2)">
			<div style="display: flex; align-items: center; gap: 12px; margin-bottom: 15px;">
				<div style="background: #EEEDFE; padding: 8px; border-radius: 8px;">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="#534AB7" stroke-width="2">
						<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
