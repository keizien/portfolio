	<script>
		const lbMap = {
1: 'pf-lightbox',
2: 'pf-lightbox2',
3: 'pf-lightbox3',
4: 'pf-lightbox4'
};
const suffixMap = {
1: '',
2: '2',
3: '3',
4: '4'
};

const pfGalleries = {
1: [
"{{ asset('documents/preuves/hotel neptune/admin chambres.png') }}",
"{{ asset('documents/preuves/hotel neptune/suppr chambre.png') }}",
"{{ asset('documents/preuves/hotel neptune/modif chambre.png') }}",
"{{ asset('documents/preuves/hotel neptune/chambres.png') }}",

],
2: [
"{{ asset('documents/preuves/hotel neptune/discord neptune.png') }}",
],
3: [
"{{ asset('documents/preuves/hotel neptune/dico.png') }}",
"{{ asset('documents/preuves/hotel neptune/dico 2.png') }}",
"{{ asset('documents/preuves/hotel neptune/mcd.png') }}",
],
4: [
"{{ asset('documents/preuves/hotel neptune/ticket glpi.png') }}",
"{{ asset('documents/preuves/hotel neptune/ticket glpi2.png') }}",
"{{ asset('documents/preuves/hotel neptune/ticket glpi3.png') }}",
]
};

const pfState = {
1: 0,
2: 0,
3: 0,
4: 0
};

function openLightbox(id) {
pfState[id] = 0;
document.getElementById(lbMap[id]).style.display = 'flex';
document.body.style.overflow = 'hidden';
renderLightbox(id);
}

function closeLightbox(id) {
document.getElementById(lbMap[id]).style.display = 'none';
document.body.style.overflow = '';
}

function nextImage(id) {
pfState[id] = (pfState[id] + 1) % pfGalleries[id].length;
renderLightbox(id);
}

function prevImage(id) {
pfState[id] = (pfState[id] - 1 + pfGalleries[id].length) % pfGalleries[id].length;
renderLightbox(id);
}

function renderLightbox(id) {
const imgs = pfGalleries[id];
const cur = pfState[id];
const suffix = suffixMap[id];
document.getElementById('pf-lb' + suffix + '-img').src = imgs[cur];
document.getElementById('pf-lb' + suffix + '-counter').textContent = (cur + 1) + ' / ' + imgs.length;
const thumbs = document.getElementById('pf-lb' + suffix + '-thumbs');
thumbs.innerHTML = '';
imgs.forEach((src, i) => {
const dot = document.createElement('div');
dot.onclick = () => {
pfState[id] = i;
renderLightbox(id);
};
dot.style.cssText = `width:8px; height:8px; border-radius:50%; cursor:pointer; transition:background 0.2s; background:${
i === cur ? '#fff' : 'rgba(255,255,255,0.3)'
}`;
thumbs.appendChild(dot);
});
}[1, 2, 3, 4].forEach(id => {
document.getElementById(lbMap[id]).addEventListener('click', function (e) {
if (e.target === this) 
closeLightbox(id);


});
});

document.addEventListener('keydown', function (e) {
const lb1 = document.getElementById('pf-lightbox').style.display !== 'none';
const lb2 = document.getElementById('pf-lightbox2').style.display !== 'none';
const lb3 = document.getElementById('pf-lightbox3').style.display !== 'none';
const lb4 = document.getElementById('pf-lightbox4').style.display !== 'none';
const id = lb1 ? 1 : lb2 ? 2 : lb3 ? 3 : lb4 ? 4 : null;
if (! id) 
return;


if (e.key === 'ArrowRight') 
nextImage(id);


if (e.key === 'ArrowLeft') 
prevImage(id);


if (e.key === 'Escape') 
closeLightbox(id);


});
	</script>

{% endblock %}
