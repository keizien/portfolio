{% extends 'base.html.twig' %}

{% block title %}Recenser et identifier les ressources numériques{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="text-center text-primary display-4 fw-bold mb-4">
        <i class="bi bi-clipboard-data-fill"></i>
        Recenser et identifier les ressources numériques
    </h1>

    <p class="text-center text-secondary fs-5 mb-5">
        Aperçu de la sous-compétence et justification de sa validation.
    </p>

    <div class="card shadow border-0 p-4">
        <h3 class="fw-bold mb-3 text-primary">Travail réalisé</h3>

        <p class="fs-5 text-muted">
            Explication
        </p>
        <h3 class="fw-bold mb-3 text-primary mt-4">Documents associés</h3>

        <div class="d-flex gap-3">
            <a href="{{ asset('competences/recenser/documentation.pdf') }}" class="btn btn-primary">
                <i class="bi bi-file-earmark-text-fill"></i> Télécharger la documentation
            </a>
            <a href="{{ asset('competences/recenser/diaporama.pdf') }}" class="btn btn-outline-primary">
                <i class="bi bi-file-earmark-ppt-fill"></i> Télécharger le diaporama
            </a>
        </div>

        <a href="{{ path('app_patrimoine_info') }}" class="btn btn-outline-secondary mt-4">
            <i class="bi bi-arrow-left"></i> Retour à la compétence : Gérer le patrimoine informatique
        </a>
    </div>
</div>
{% endblock %}
