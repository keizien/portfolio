{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }}Compétence — Patrimoine Informatique
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sora', sans-serif; background-color: #fff; }

        /* Header Style cohérent avec les projets */
        .pf-page-header {
            padding: 4rem 3rem 3rem;
            border-bottom: 1px solid #e5e7eb;
            background: linear-gradient(to bottom right, #f9fafb, #f3f4f6);
        }

        .pf-page-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-family: 'Space Mono', monospace;
            font-size: 11px;
            color: #3b82f6; /* Bleu pour le patrimoine */
            background: #eff6ff;
            border: 1px solid #dbeafe;
            border-radius: 100px;
            padding: 4px 14px;
            margin-bottom: 1.25rem;
        }

        .pf-page-title {
            font-size: clamp(28px, 4vw, 40px);
            font-weight: 700;
            letter-spacing: -1.5px;
            color: #111827;
            margin: 0 0 1rem;
        }

        .pf-page-title em { font-style: normal; color: #3b82f6; }

        /* Layout */
        .pf-container { max-width: 1100px; margin: 0 auto; padding: 3rem; }

        /* Section Sous-compétences */
        .pf-grid-skills {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
            margin-bottom: 4rem;
        }

        .pf-skill-card {
            padding: 1.5rem;
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            display: flex;
            gap: 15px;
            transition: all 0.2s;
        }

        .pf-skill-card:hover { border-color: #3b82f6; transform: translateY(-2px); }

        .pf-skill-icon {
            color: #3b82f6;
            flex-shrink: 0;
            margin-top: 3px;
        }

        .pf-skill-text { font-size: 14px; color: #4b5563; line-height: 1.5; font-weight: 500; }

        /* Section Projets Associés */
        .pf-section-label {
            font-family: 'Space Mono', monospace;
            font-size: 12px;
            color: #9ca3af;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 2rem;
            text-align: center;
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .pf-section-label::before, .pf-section-label::after { content: ""; height: 1px; background: #e5e7eb; flex: 1; }

        .pf-project-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
			gap: 1.5rem;
		}

        .pf-project-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            padding: 2rem;
            text-decoration: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
        }

        .pf-project-card:hover {
            border-color: #3b82f6;
            box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.1);
        }

        .pf-project-name { font-size: 18px; font-weight: 700; color: #111827; margin-bottom: 10px; }
        .pf-project-desc { font-size: 14px; color: #6b7280; line-height: 1.6; margin-bottom: 1.5rem; flex-grow: 1; }

        .pf-project-link {
            font-family: 'Space Mono', monospace;
            font-size: 12px;
            font-weight: 700;
            color: #3b82f6;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Back Bar */
        .pf-back-bar { padding: 2rem 3rem; border-top: 1px solid #e5e7eb; margin-top: 2rem; }
        .pf-btn-back { font-size: 13px; font-family: 'Space Mono', monospace; color: #6b7280; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; }
        .pf-btn-back:hover { color: #3b82f6; }

        @media (max-width: 768px) {
            .pf-project-grid { grid-template-columns: 1fr; }
            .pf-container { padding: 1.5rem; }
        }
    </style>
{% endblock %}

{% block body %}

<div class="pf-page-header">
    <div class="pf-page-badge">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>
        </svg>
        Compétence 1
    </div>
    <h1 class="pf-page-title">Gérer le <em>patrimoine</em> informatique</h1>
    <p class="pf-page-sub">Maintenir, organiser et optimiser les ressources numériques d’une structure.</p>
</div>

<div class="pf-container">
    
    <div class="pf-grid-skills">
        {% set skills = [
            "Recenser et identifier les ressources numériques",
            "Exploiter les caractéristiques d’un équipement ou d’un service",
            "Installer, déployer et configurer un poste de travail",
            "Vérifier les conditions de continuité d’un service",
            "Gérer les sauvegardes et la restauration des données",
            "Vérifier le respect des règles d’utilisation des ressources"
        ] %}

        {% for skill in skills %}
        <div class="pf-skill-card">
            <div class="pf-skill-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
            </div>
            <div class="pf-skill-text">{{ skill }}</div>
        </div>
        {% endfor %}
    </div>

    <div class="pf-section-label">Réalisations associées</div>

    <div class="pf-project-grid">
        <a href="{{ path('app_apProjet') }}" class="pf-project-card">
            <div class="pf-project-name">AP Projet 1</div>
            <p class="pf-project-desc">Mise en place d'un service d'organisation et de gestion de stockage des fichiers ZIP/PPTX.</p>
            <div class="pf-project-link">
                Voir le projet 
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
            </div>
        </a>

        <a href="{{ path('app_stage1') }}" class="pf-project-card">
            <div class="pf-project-name">Stage SNCF Infrapole</div>
            <p class="pf-project-desc">Automatisation de flux Power Automate et intégration Power BI pour la gestion du patrimoine data.</p>
            <div class="pf-project-link">
                Voir le projet 
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
            </div>
        </a>

        <a href="{{ path('app_infra_reseau') }}" class="pf-project-card">
            <div class="pf-project-name">Projet Infra-Réseau</div>
            <p class="pf-project-desc">Conception d'une architecture sécurisée avec documentation technique et planification des déploiements.</p>
            <div class="pf-project-link">
                Voir le projet 
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
            </div>
        </a>

        <a href="{{ path('app_workshop_SN2') }}" class="pf-project-card">
            <div class="pf-project-name">Workshop MI6 — Time2Spy</div>
            <p class="pf-project-desc">Gestion de projet collaboratif en équipe. Répartition des tâches techniques (Python/IoT) et suivi via méthodologie agile.</p>
            <div class="pf-project-link">
                Voir le projet 
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
            </div>
        </a>
    </div>

</div>

<div class="pf-back-bar">
    <a href="{{ path('app_competences') }}" class="pf-btn-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        Retour aux compétences
    </a>
</div>

{% endblock %}