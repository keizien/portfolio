{% extends 'base.html.twig' %}

{% block title %}
	{{ parent() }}Compétence — Mise à disposition de services
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
	<style>
		body {
			font-family: 'Sora', sans-serif;
			background-color: #fff;
		}

		/* Header Style avec la couleur Orange C5 */
		.pf-page-header {
			padding: 4rem 3rem 3rem;
			border-bottom: 1px solid #e5e7eb;
			background: linear-gradient(to bottom right, #fffaf5, #fff7ed);
		}

		.pf-page-badge {
			display: inline-flex;
			align-items: center;
			gap: 7px;
			font-family: 'Space Mono', monospace;
			font-size: 11px;
			color: #f97316; /* Orange C5 */
			background: #fff7ed;
			border: 1px solid #ffedd5;
			border-radius: 100px;
			padding: 4px 14px;
			margin-bottom: 1.25rem;
		}

		.pf-page-title {
			font-size: clamp(28px, 4vw, 40px);
			font-weight: 700;
			letter-spacing: -1.5px;
			color: #111827;
			margin: 0 0 1rem;
		}

		.pf-page-title em {
			font-style: normal;
			color: #f97316;
		}

		/* Layout */
		.pf-container {
			max-width: 1200px;
			margin: 0 auto;
			padding: 3rem;
		}

		/* Section Sous-compétences */
		.pf-grid-skills {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
			gap: 1.5rem;
			margin-bottom: 4rem;
		}

		.pf-skill-card {
			padding: 1.25rem;
			background: #fff;
			border: 1px solid #e5e7eb;
			border-radius: 12px;
			display: flex;
			gap: 12px;
			transition: all 0.2s;
		}

		.pf-skill-card:hover {
			border-color: #f97316;
			transform: translateY(-2px);
		}
		.pf-skill-icon {
			color: #f97316;
			flex-shrink: 0;
			margin-top: 2px;
		}
		.pf-skill-text {
			font-size: 13px;
			color: #4b5563;
			line-height: 1.5;
			font-weight: 500;
		}

		/* Section Projets Associés */
		.pf-section-label {
			font-family: 'Space Mono', monospace;
			font-size: 12px;
			color: #9ca3af;
			text-transform: uppercase;
			letter-spacing: 2px;
			margin-bottom: 2rem;
			text-align: center;
			display: flex;
			align-items: center;
			gap: 15px;
		}
		.pf-section-label::before,
		.pf-section-label::after {
			content: "";
			height: 1px;
			background: #e5e7eb;
			flex: 1;
		}

		.pf-project-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
			gap: 1.5rem;
		}

		.pf-project-card {
			background: #fff;
			border: 1px solid #e5e7eb;
			border-radius: 14px;
			padding: 1.75rem;
			text-decoration: none;
			transition: all 0.3s ease;
			display: flex;
			flex-direction: column;
			height: 100%;
		}

		.pf-project-card:hover {
			border-color: #f97316;
			box-shadow: 0 10px 20px -5px rgba(249, 115, 22, 0.1);
		}

		.pf-project-name {
			font-size: 16px;
			font-weight: 700;
			color: #111827;
			margin-bottom: 8px;
		}
		.pf-project-desc {
			font-size: 13px;
			color: #6b7280;
			line-height: 1.6;
			margin-bottom: 1.25rem;
			flex-grow: 1;
		}

		.pf-project-list {
			padding-left: 1.2rem;
			margin-bottom: 1.25rem;
			font-size: 13px;
			color: #6b7280;
		}

		.pf-project-link {
			font-family: 'Space Mono', monospace;
			font-size: 11px;
			font-weight: 700;
			color: #f97316;
			display: flex;
			align-items: center;
			gap: 6px;
		}

		/* Back Bar */
		.pf-back-bar {
			padding: 2rem 3rem;
			border-top: 1px solid #e5e7eb;
			margin-top: 2rem;
		}
		.pf-btn-back {
			font-size: 13px;
			font-family: 'Space Mono', monospace;
			color: #6b7280;
			text-decoration: none;
			display: inline-flex;
			align-items: center;
			gap: 8px;
		}
		.pf-btn-back:hover {
			color: #f97316;
		}

		@media(max-width: 768px) {
			.pf-container {
				padding: 1.5rem;
			}
			.pf-project-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>
{% endblock %}

{% block body %}

	<div class="pf-page-header">
		<div class="pf-page-badge">
			<svg width="12" height="12" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
				<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
			</svg>
			Compétence 5
		</div>
		<h1 class="pf-page-title">Mettre à disposition un
			<em>service</em>
		</h1>
		<p class="pf-page-sub">Déployer, tester et accompagner les utilisateurs dans l'appropriation des solutions informatiques.</p>
	</div>

	<div class="pf-container">

		<div class="pf-grid-skills">
			{% set skills = [
            "Réaliser les tests d’intégration et d’acceptation d’un service",
            "Déployer un service informatique",
            "Accompagner les utilisateurs dans la mise en place du service",
            "Documenter le service pour les utilisateurs et techniciens"
        ] %}

			{% for skill in skills %}
				<div class="pf-skill-card">
					<div class="pf-skill-icon">
						<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
							<polyline points="20 6 9 17 4 12"></polyline>
						</svg>
					</div>
					<div class="pf-skill-text">{{ skill }}</div>
				</div>
			{% endfor %}
		</div>

		<div class="pf-section-label">Réalisations associées</div>

		<div class="pf-project-grid">
			<a href="{{ path('app_solution_web') }}" class="pf-project-card">
				<div class="pf-project-name">Service Web Livrables</div>
				<p class="pf-project-desc">Déploiement complet d’une solution PHP de gestion de fichiers. Tests fonctionnels et mise en production d'une interface responsive.</p>
				<div class="pf-project-link">Voir le projet →</div>
			</a>

			<a href="{{ path('app_workshop_SN2') }}" class="pf-project-card">
				<div class="pf-project-name">Workshop — Time2Spy</div>
				<p class="pf-project-desc">Mise en service d'un système IoT. Tests de communication sécurisée entre dispositifs et validation du matériel (micro/LED).</p>
				<div class="pf-project-link">Voir le projet →</div>
			</a>

			<a href="{{ path('app_stage1') }}" class="pf-project-card">
				<div class="pf-project-name">Stage SNCF Infrapole</div>
				<ul class="pf-project-list">
					<li>Déploiement de tableaux Power BI</li>
					<li>Mise à disposition de flux Power Automate</li>
					<li>Accompagnement des collaborateurs</li>
				</ul>
				<div class="pf-project-link">Voir le projet →</div>
			</a>

			<a href="{{ path('app_infra_reseau') }}" class="pf-project-card">
				<div class="pf-project-name">Infrastructure Réseaux</div>
				<p class="pf-project-desc">Mise à disposition d'une architecture système complète, configurée et testée pour répondre aux besoins d'une organisation.</p>
				<div class="pf-project-link">Voir le projet →</div>
			</a>

			<a href="{{ path('app_neptune') }}" class="pf-project-card">
				<div class="pf-project-name">Projet Hôtel Neptune</div>
				<p class="pf-project-desc">Mise en place d'un service de gestion de base de données exploitable par une interface métier.</p>
				<div class="pf-project-link">Voir le projet →</div>
			</a>
		</div>

	</div>

	<div class="pf-back-bar">
		<a href="{{ path('app_competences') }}" class="pf-btn-back">
			<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
				<line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
			</svg>
			Retour aux compétences
		</a>
	</div>

{% endblock %}
