{% extends 'base.html.twig' %}

{% block title %}
	{{ parent() }}Compétence — Développement Professionnel
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
	<style>
		body {
			font-family: 'Sora', sans-serif;
			background-color: #fff;
		}

		/* Header Style avec la couleur Vert Clair C6 */
		.pf-page-header {
			padding: 4rem 3rem 3rem;
			border-bottom: 1px solid #e5e7eb;
			background: linear-gradient(to bottom right, #fafff7, #f0fdf4);
		}

		.pf-page-badge {
			display: inline-flex;
			align-items: center;
			gap: 7px;
			font-family: 'Space Mono', monospace;
			font-size: 11px;
			color: #65a30d; /* Vert C6 */
			background: #f0fdf4;
			border: 1px solid #dcfce7;
			border-radius: 100px;
			padding: 4px 14px;
			margin-bottom: 1.25rem;
		}

		.pf-page-title {
			font-size: clamp(28px, 4vw, 40px);
			font-weight: 700;
			letter-spacing: -1.5px;
			color: #111827;
			margin: 0 0 1rem;
		}

		.pf-page-title em {
			font-style: normal;
			color: #84cc16;
		}

		/* Layout */
		.pf-container {
			max-width: 1100px;
			margin: 0 auto;
			padding: 3rem;
		}

		/* Section Sous-compétences */
		.pf-grid-skills {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
			gap: 1.5rem;
			margin-bottom: 4rem;
		}

		.pf-skill-card {
			padding: 1.5rem;
			background: #fff;
			border: 1px solid #e5e7eb;
			border-radius: 12px;
			display: flex;
			gap: 15px;
			transition: all 0.2s;
		}

		.pf-skill-card:hover {
			border-color: #84cc16;
			transform: translateY(-2px);
		}

		.pf-skill-icon {
			color: #84cc16;
			flex-shrink: 0;
			margin-top: 3px;
		}
		.pf-skill-text {
			font-size: 14px;
			color: #4b5563;
			line-height: 1.5;
			font-weight: 500;
		}

		/* Section Projets Associés */
		.pf-section-label {
			font-family: 'Space Mono', monospace;
			font-size: 12px;
			color: #9ca3af;
			text-transform: uppercase;
			letter-spacing: 2px;
			margin-bottom: 2rem;
			text-align: center;
			display: flex;
			align-items: center;
			gap: 15px;
		}
		.pf-section-label::before,
		.pf-section-label::after {
			content: "";
			height: 1px;
			background: #e5e7eb;
			flex: 1;
		}

		.pf-project-card {
			background: #fff;
			border: 1px solid #e5e7eb;
			border-radius: 16px;
			padding: 2.5rem;
			text-decoration: none;
			transition: all 0.3s ease;
			display: flex;
			align-items: center;
			justify-content: space-between;
			max-width: 600px;
			margin: 0 auto;
		}

		.pf-project-card:hover {
			border-color: #84cc16;
			box-shadow: 0 10px 25px -5px rgba(132, 204, 22, 0.1);
		}

		.pf-project-name {
			font-size: 18px;
			font-weight: 700;
			color: #111827;
		}

		.pf-project-link {
			font-family: 'Space Mono', monospace;
			font-size: 12px;
			font-weight: 700;
			color: #65a30d;
			display: flex;
			align-items: center;
			gap: 8px;
		}

		/* Back Bar */
		.pf-back-bar {
			padding: 2rem 3rem;
			border-top: 1px solid #e5e7eb;
			margin-top: 2rem;
		}
		.pf-btn-back {
			font-size: 13px;
			font-family: 'Space Mono', monospace;
			color: #6b7280;
			text-decoration: none;
			display: inline-flex;
			align-items: center;
			gap: 8px;
		}
		.pf-btn-back:hover {
			color: #84cc16;
		}

		@media(max-width: 768px) {
			.pf-container {
				padding: 1.5rem;
			}
		}

		.pf-project-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
			gap: 1.5rem;
		}
	</style>
{% endblock %}

{% block body %}

	<div class="pf-page-header">
		<div class="pf-page-badge">
			<svg width="12" height="12" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
				<path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/>
			</svg>
			Compétence 6
		</div>
		<h1 class="pf-page-title">Développement
			<em>professionnel</em>
		</h1>
		<p class="pf-page-sub">Gérer sa veille technologique, son identité numérique et son parcours de formation.</p>
	</div>

	<div class="pf-container">

		<div class="pf-grid-skills">
			{% set skills = [
            "Mettre en place son environnement d’apprentissage personnel",
            "Mettre en œuvre des stratégies de veille technologique",
            "Gérer son identité professionnelle en ligne",
            "Développer et valoriser son projet professionnel"
        ] %}

			{% for skill in skills %}
				<div class="pf-skill-card">
					<div class="pf-skill-icon">
						<svg width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
							<polyline points="20 6 9 17 4 12"></polyline>
						</svg>
					</div>
					<div class="pf-skill-text">{{ skill }}</div>
				</div>
			{% endfor %}
		</div>

		<div class="pf-section-label">Réalisation principale</div>

		<div class="pf-project-grid">
			<a href="{{ path('app_accueil') }}" class="pf-project-card">
				<div>
					<div class="pf-project-name">Conception du Portfolio</div>
					<div style="font-size: 14px; color: #6b7280; margin-top: 5px;">Synthèse des compétences et valorisation du parcours.</div>
				</div>
				<div class="pf-project-link" style="background: #f0fdf4; padding: 8px 16px; border-radius: 8px; border: 1px solid #dcfce7; align-self: flex-end;">
					Voir l'accueil
					<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-left: 5px;">
						<line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
					</svg>
				</div>
			</a>

			<a href="{{ path('app_arcachon') }}" class="pf-project-card">
				<div>
					<div class="pf-project-name">Projet Arcachon</div>
					<div style="font-size: 14px; color: #6b7280; margin-top: 5px;">Développement web complet respectant un cahier des charges client strict et une planification par jalons.</div>
					<div class="pf-project-link">Voir le projet →</div>
				</div>
			</a>

			<a href="{{ path('app_workshop_SN2') }}" class="pf-project-card">
				<div>
					<div class="pf-project-name">Workshop MI6 — Time2Spy</div>
					<div style="font-size: 14px; color: #6b7280; margin-top: 5px;">Gestion de projet collaboratif en équipe. Répartition des tâches techniques (Python/IoT) et suivi via méthodologie agile.</div>
					<div class="pf-project-link">Voir le projet →</div>
				</div>
			</a>
		</div>

	</div>

	<div class="pf-back-bar">
		<a href="{{ path('app_competences') }}" class="pf-btn-back">
			<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
				<line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
			</svg>
			Retour aux compétences
		</a>
	</div>

{% endblock %}
