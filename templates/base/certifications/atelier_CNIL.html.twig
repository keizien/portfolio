{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }}Atelier CNIL — Protection des données
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sora', sans-serif; background-color: #fff; }

        /* Header Style (Ambre pour Certifications) */
        .pf-page-header {
            padding: 4rem 3rem 3rem;
            border-bottom: 1px solid #e5e7eb;
            background: linear-gradient(to bottom right, #fffdfa, #fef3c7);
        }

        .pf-page-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-family: 'Space Mono', monospace;
            font-size: 11px;
            color: #b45309;
            background: #fffbeb;
            border: 1px solid #fde68a;
            border-radius: 100px;
            padding: 4px 14px;
            margin-bottom: 1.25rem;
        }

        .pf-page-title {
            font-size: clamp(28px, 4vw, 40px);
            font-weight: 700;
            letter-spacing: -1.5px;
            color: #111827;
            margin: 0 0 1rem;
        }

        .pf-page-title em { font-style: normal; color: #d97706; }

        /* Layout */
        .pf-container { max-width: 1100px; margin: 0 auto; padding: 3rem; }

        /* Intro Card */
        .pf-intro-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            padding: 2rem;
            margin-bottom: 3rem;
        }

        /* Grid des modules */
        .pf-cert-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .pf-cert-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            transition: all 0.3s ease;
        }

        .pf-cert-card:hover {
            border-color: #f59e0b;
            transform: translateY(-4px);
            box-shadow: 0 10px 25px -5px rgba(217, 119, 6, 0.1);
        }

        .pf-module-num {
            font-family: 'Space Mono', monospace;
            font-size: 12px;
            font-weight: 700;
            color: #d97706;
            margin-bottom: 0.5rem;
        }

        .pf-module-name {
            font-size: 16px;
            font-weight: 700;
            color: #111827;
            margin-bottom: 1rem;
        }

        /* BOUTON MODIFIE */
        .pf-btn-view {
            margin-top: auto;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 10px;
            font-size: 13px;
            font-weight: 600;
            color: #475569;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.2s;
            cursor: pointer;
            width: 100%;
        }

        .pf-btn-view:hover {
            background: #111827;
            color: #fff;
            border-color: #111827;
        }

        /* Style de la modale PDF */
        .modal-content { border-radius: 15px; border: none; overflow: hidden; }
        .pdf-iframe { width: 100%; height: 75vh; border: none; }

        /* Back Bar */
        .pf-back-bar { padding: 2rem 3rem; border-top: 1px solid #e5e7eb; margin-top: 2rem; }
        .pf-btn-back { font-size: 13px; font-family: 'Space Mono', monospace; color: #6b7280; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; }
        .pf-btn-back:hover { color: #d97706; }
    </style>
{% endblock %}

{% block body %}

<div class="pf-page-header">
    <div class="pf-page-badge">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        MOOC Certifiant
    </div>
    <h1 class="pf-page-title">Atelier <em>CNIL</em></h1>
    <p class="pf-page-sub">Maîtriser les enjeux de la protection des données et du RGPD.</p>
</div>

<div class="pf-container">
    
    <div class="pf-intro-card">
        <h3 class="fw-bold text-dark mb-3">Sensibilisation au RGPD</h3>
        <p class="text-muted mb-0">
            Cette formation permet d'appréhender les principes clés du Règlement Général sur la Protection des Données. 
            Elle certifie ma capacité à intégrer la sécurité des données dès la conception de mes projets de développement.
        </p>
    </div>

    {% set modules = [
        "Le RGPD et ses notions clés",
        "Les principes de la protection des données",
        "Les responsabilités des acteurs",
        "Le respect des droits des personnes",
        "La sécurisation des données personnelles",
        "Le pilotage de la conformité"
    ] %}

    {% set links = [
        'documents/atelier_CNIL/Attestation_de_suivi.pdf',
        'documents/atelier_CNIL/Attestation_de_suivi_2.pdf',
        'documents/atelier_CNIL/Attestation module 3.pdf',
        'documents/atelier_CNIL/Attestation module 4.pdf',
        'documents/atelier_CNIL/Attestation module 5.pdf',
        'documents/atelier_CNIL/Attestation module 6.pdf'
    ] %}

    <div class="pf-cert-grid">
        {% for i in 1..6 %}
            <div class="pf-cert-card">
                <div class="pf-module-num">Module 0{{ i }}</div>
                <div class="pf-module-name">{{ modules[i-1] }}</div>
                
                {# Bouton qui ouvre la modale au lieu de télécharger #}
                <button class="pf-btn-view" data-bs-toggle="modal" data-bs-target="#modalCnil{{ i }}">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                    </svg>
                    Voir l'attestation
                </button>
            </div>

            {# Modale correspondante #}
            <div class="modal fade" id="modalCnil{{ i }}" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-xl modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title fw-bold">Module {{ i }} : {{ modules[i-1] }}</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body p-0">
                            <iframe class="pdf-iframe" src="{{ asset(links[i-1]) }}#toolbar=0"></iframe>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

</div>

<div class="pf-back-bar">
    <a href="{{ path('app_certifications') }}" class="pf-btn-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        Retour aux certifications
    </a>
</div>

{% endblock %}