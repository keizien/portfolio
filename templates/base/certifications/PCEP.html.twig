{% extends 'base.html.twig' %}

{% block title %}
	{{ parent() }}Certification — PCEP™
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
	<style>
		body {
			font-family: 'Sora', sans-serif;
		}
		.pf-page-header {
			padding: 3.5rem 3rem 2.5rem;
			border-bottom: 1px solid #e5e7eb;
		}
		.pf-page-badge {
			display: inline-flex;
			align-items: center;
			gap: 7px;
			font-family: 'Space Mono', monospace;
			font-size: 11px;
			color: #4338CA;
			background: #EEF2FF;
			border: 1px solid #C7D2FE;
			border-radius: 100px;
			padding: 4px 14px;
			margin-bottom: 1.25rem;
		}
		.pf-page-title {
			font-size: clamp(28px, 4vw, 44px);
			font-weight: 700;
			letter-spacing: -1.5px;
			line-height: 1.1;
			color: #111827;
			margin: 0 0 0.75rem;
		}
		.pf-page-title em {
			font-style: normal;
			color: #6366F1;
		}
		.pf-page-sub {
			font-size: 15px;
			color: #6b7280;
			margin: 0;
		}
		.pf-stage-layout {
			display: grid;
			grid-template-columns: 280px 1fr;
			border-bottom: 1px solid #e5e7eb;
		}
		.pf-sidebar {
			padding: 3rem 2rem;
			border-right: 1px solid #e5e7eb;
			background: #f9fafb;
			display: flex;
			flex-direction: column;
			gap: 3rem;
		}
		.pf-sidebar-label {
			font-family: 'Space Mono', monospace;
			font-size: 10px;
			color: #9ca3af;
			text-transform: uppercase;
			letter-spacing: 1px;
			margin-bottom: 10px;
		}
		.pf-info-row {
			display: flex;
			justify-content: space-between;
			align-items: center;
			font-size: 12px;
			padding: 6px 0;
			border-bottom: 1px solid #f3f4f6;
		}
		.pf-info-row:last-child {
			border-bottom: none;
		}
		.pf-info-label {
			color: #9ca3af;
			font-family: 'Space Mono', monospace;
			font-size: 10px;
		}
		.pf-info-value {
			color: #374151;
			font-weight: 600;
			font-size: 12px;
			text-align: right;
		}
		.pf-skill-pill {
			display: inline-block;
			font-size: 11px;
			font-family: 'Space Mono', monospace;
			padding: 2px 10px;
			background: #f3f4f6;
			border-radius: 4px;
			color: #4b5563;
			margin-right: 5px;
			margin-bottom: 5px;
		}
		.pf-main {
			display: flex;
			flex-direction: column;
		}
		.pf-section {
			padding: 2.5rem 3rem;
			border-bottom: 1px solid #e5e7eb;
		}
		.pf-section:last-child {
			border-bottom: none;
		}
		.pf-section-title {
			font-size: 17px;
			font-weight: 700;
			color: #111827;
			margin: 0 0 1rem;
			display: flex;
			align-items: center;
			gap: 10px;
		}
		.pf-section-title::before {
			content: '';
			width: 3px;
			height: 17px;
			background: #6366F1;
			border-radius: 2px;
		}
		.pf-prose {
			font-size: 14px;
			color: #374151;
			line-height: 1.85;
			margin: 0;
		}
		.pf-prose ul {
			padding-left: 1.25rem;
			margin: 0;
		}
		.pf-prose li {
			margin-bottom: 0.4rem;
		}
		.pf-back-bar {
			padding: 1.25rem 3rem;
			border-top: 1px solid #e5e7eb;
		}
		.pf-btn-back {
			font-size: 13px;
			font-family: 'Space Mono', monospace;
			color: #6b7280;
			text-decoration: none;
			display: inline-flex;
			align-items: center;
			gap: 6px;
		}
		.pf-btn-back:hover {
			color: #6366F1;
		}

		{# ── Badge certif central ── #}
		.certif-hero {
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			padding: 3rem 2rem;
			background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
			border-radius: 16px;
			text-align: center;
			margin-bottom: 1.5rem;
			position: relative;
			overflow: hidden;
		}
		.certif-hero::before {
			content: '';
			position: absolute;
			inset: 0;
			background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
		}
		.certif-logo {
			width: 72px;
			height: 72px;
			background: rgba(255,255,255,0.1);
			border-radius: 50%;
			display: flex;
			align-items: center;
			justify-content: center;
			margin-bottom: 1.25rem;
			border: 2px solid rgba(255,255,255,0.2);
		}
		.certif-code {
			font-family: 'Space Mono', monospace;
			font-size: 13px;
			color: #a5b4fc;
			letter-spacing: 3px;
			margin-bottom: 0.5rem;
		}
		.certif-name {
			font-size: 22px;
			font-weight: 700;
			color: #ffffff;
			margin-bottom: 0.5rem;
			line-height: 1.2;
		}
		.certif-fullname {
			font-size: 13px;
			color: #c7d2fe;
			margin-bottom: 1.5rem;
		}
		.certif-status-badge {
			display: inline-flex;
			align-items: center;
			gap: 6px;
			background: rgba(234, 179, 8, 0.15);
			border: 1px solid rgba(234, 179, 8, 0.4);
			color: #fde047;
			font-family: 'Space Mono', monospace;
			font-size: 11px;
			font-weight: 700;
			padding: 6px 14px;
			border-radius: 100px;
			letter-spacing: 1px;
		}
		.certif-status-dot {
			width: 6px;
			height: 6px;
			border-radius: 50%;
			background: #fde047;
			animation: pulse 1.8s ease-in-out infinite;
		}
		@keyframes pulse {
			0%, 100% { opacity: 1; }
			50% { opacity: 0.3; }
		}

		{# ── Grille thèmes exam ── #}
		.exam-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
			gap: 12px;
			margin-top: 1rem;
		}
		.exam-card {
			background: #f9fafb;
			border: 1px solid #e5e7eb;
			border-radius: 10px;
			padding: 14px 16px;
		}
		.exam-card-title {
			font-size: 12px;
			font-weight: 700;
			color: #111827;
			margin-bottom: 4px;
		}
		.exam-card-pct {
			font-family: 'Space Mono', monospace;
			font-size: 11px;
			color: #6366F1;
			font-weight: 700;
		}
		.exam-bar {
			height: 4px;
			background: #e5e7eb;
			border-radius: 2px;
			margin-top: 8px;
			overflow: hidden;
		}
		.exam-bar-fill {
			height: 100%;
			background: linear-gradient(90deg, #6366F1, #818cf8);
			border-radius: 2px;
		}

		@media(max-width: 850px) {
			.pf-stage-layout {
				grid-template-columns: 1fr;
			}
			.pf-sidebar {
				border-right: none;
				border-bottom: 1px solid #e5e7eb;
			}
		}
	</style>
{% endblock %}

{% block body %}

	{# ── En-tête ── #}
	<div class="pf-page-header">
		<div class="pf-page-badge">
			<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
				<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
			</svg>
			Certification
		</div>
		<h1 class="pf-page-title">PCEP™ — <em>Python</em> Certified</h1>
		<p class="pf-page-sub">Certified Entry-Level Python Programmer — Python Institute</p>
	</div>

	<div class="pf-stage-layout">

		{# ── Sidebar ── #}
		<aside class="pf-sidebar">
			<div>
				<div class="pf-sidebar-label">Informations</div>
				<div class="pf-info-row">
					<span class="pf-info-label">Organisme</span>
					<span class="pf-info-value">Python Institute</span>
				</div>
				<div class="pf-info-row">
					<span class="pf-info-label">Code examen</span>
					<span class="pf-info-value">PCEP-30-02</span>
				</div>
				<div class="pf-info-row">
					<span class="pf-info-label">Durée</span>
					<span class="pf-info-value">45 min</span>
				</div>
				<div class="pf-info-row">
					<span class="pf-info-label">Questions</span>
					<span class="pf-info-value">30 questions</span>
				</div>
				<div class="pf-info-row">
					<span class="pf-info-label">Score requis</span>
					<span class="pf-info-value">70 %</span>
				</div>
				<div class="pf-info-row">
					<span class="pf-info-label">Statut</span>
					<span class="pf-info-value" style="color: #ca8a04;">En préparation</span>
				</div>
			</div>

			<div>
				<div class="pf-sidebar-label">Compétences visées</div>
				<span class="pf-skill-pill">Python 3</span>
				<span class="pf-skill-pill">Types & variables</span>
				<span class="pf-skill-pill">Fonctions</span>
				<span class="pf-skill-pill">Conditions</span>
				<span class="pf-skill-pill">Boucles</span>
				<span class="pf-skill-pill">Listes & tuples</span>
				<span class="pf-skill-pill">Modules</span>
				<span class="pf-skill-pill">Exceptions</span>
			</div>
		</aside>

		{# ── Contenu principal ── #}
		<main class="pf-main">

			<section class="pf-section">
				<h2 class="pf-section-title">Présentation de la certification</h2>
				<div class="pf-prose">

					{# Badge central #}
					<div class="certif-hero">
						<div class="certif-logo">
							<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="1.5">
								<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
							</svg>
						</div>
						<div class="certif-code">PCEP-30-02</div>
						<div class="certif-name">PCEP™</div>
						<div class="certif-fullname">Certified Entry-Level Python Programmer</div>
						<div class="certif-status-badge">
							<span class="certif-status-dot"></span>
							En cours de préparation
						</div>
					</div>

					<p>Le <strong>PCEP™</strong> (Certified Entry-Level Python Programmer) est une certification délivrée par le <strong>Python Institute</strong>, organisme de référence international pour les certifications Python. Elle valide les compétences fondamentales en programmation Python et constitue le premier niveau d'une voie de certification reconnue dans le secteur.</p>
					<p>Cette certification atteste de la maîtrise des bases du langage Python : syntaxe, types de données, structures de contrôle, fonctions et gestion des exceptions.</p>
				</div>
			</section>

			<section class="pf-section">
				<h2 class="pf-section-title">Pourquoi cette certification ?</h2>
				<div class="pf-prose">
					<p>Durant mon stage chez <strong>OpteSite</strong>, j'ai développé de manière autonome plusieurs scripts Python complexes : scraping avec BeautifulSoup, interrogation d'APIs REST et GraphQL, programmation asynchrone avec <code>asyncio</code> et <code>aiohttp</code>. Ces compétences ont été acquises en situation réelle, sans formation préalable.</p>
					<p>Le PCEP™ me permet de <strong>valider formellement</strong> ces acquis pratiques et de renforcer mon profil en vue de mon entrée en <strong>Bachelor DevOps</strong> à la rentrée 2026, où Python occupe une place centrale dans l'automatisation et l'infrastructure.</p>
				</div>
			</section>

			<section class="pf-section">
				<h2 class="pf-section-title">Contenu de l'examen</h2>
				<div class="pf-prose">
					<p>L'examen PCEP-30-02 couvre quatre grands blocs de compétences :</p>
					<div class="exam-grid">
						<div class="exam-card">
							<div class="exam-card-title">Fondamentaux Python</div>
							<div class="exam-card-pct">18 %</div>
							<div class="exam-bar"><div class="exam-bar-fill" style="width:18%"></div></div>
						</div>
						<div class="exam-card">
							<div class="exam-card-title">Types de données & opérations</div>
							<div class="exam-card-pct">29 %</div>
							<div class="exam-bar"><div class="exam-bar-fill" style="width:29%"></div></div>
						</div>
						<div class="exam-card">
							<div class="exam-card-title">Contrôle du flux & fonctions</div>
							<div class="exam-card-pct">29 %</div>
							<div class="exam-bar"><div class="exam-bar-fill" style="width:29%"></div></div>
						</div>
						<div class="exam-card">
							<div class="exam-card-title">Structures de données</div>
							<div class="exam-card-pct">24 %</div>
							<div class="exam-bar"><div class="exam-bar-fill" style="width:24%"></div></div>
						</div>
					</div>
				</div>
			</section>

			<section class="pf-section">
				<h2 class="pf-section-title">Lien avec mes réalisations</h2>
				<div class="pf-prose">
					<ul>
						<li><strong>Stage SN2 — OpteSite :</strong> scripts de web scraping, migration WooCommerce via API, prospection Croc'Poker avec GraphQL et asyncio.</li>
						<li><strong>Workshop SN2 — Time2Spy :</strong> chiffrement AES, communication TCP, pilotage des GPIO du Raspberry Pi en Python.</li>
						<li><strong>AP Projet 1 :</strong> scripts Bash/Python pour la sauvegarde automatisée et chiffrée d'une base de données MariaDB.</li>
					</ul>
				</div>
			</section>

		</main>
	</div>

	<div class="pf-back-bar">
		<a href="{{ path('app_projets') }}" class="pf-btn-back">
			<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
			</svg>
			Retour aux projets
		</a>
	</div>

{% endblock %}
