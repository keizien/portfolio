{% extends 'base.html.twig' %}

{% block title %}
	{{ parent() }}Compétence — Incidents & Assistance
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
	<style>
		body {
			font-family: 'Sora', sans-serif;
			background-color: #fff;
		}

		/* Header Style avec la couleur Orange C2 */
		.pf-page-header {
			padding: 4rem 3rem 3rem;
			border-bottom: 1px solid #e5e7eb;
			background: linear-gradient(to bottom right, #fffcf9, #fff7ed);
		}

		.pf-page-badge {
			display: inline-flex;
			align-items: center;
			gap: 7px;
			font-family: 'Space Mono', monospace;
			font-size: 11px;
			color: #d97706; /* Orange C2 */
			background: #fff7ed;
			border: 1px solid #ffedd5;
			border-radius: 100px;
			padding: 4px 14px;
			margin-bottom: 1.25rem;
		}

		.pf-page-title {
			font-size: clamp(28px, 4vw, 40px);
			font-weight: 700;
			letter-spacing: -1.5px;
			color: #111827;
			margin: 0 0 1rem;
		}

		.pf-page-title em {
			font-style: normal;
			color: #d97706;
		}

		/* Layout */
		.pf-container {
			max-width: 1100px;
			margin: 0 auto;
			padding: 3rem;
		}

		/* Section Sous-compétences */
		.pf-grid-skills {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
			gap: 1.5rem;
			margin-bottom: 4rem;
		}

		.pf-skill-card {
			padding: 1.5rem;
			background: #fff;
			border: 1px solid #e5e7eb;
			border-radius: 12px;
			display: flex;
			gap: 15px;
			transition: all 0.2s;
		}

		.pf-skill-card:hover {
			border-color: #d97706;
			transform: translateY(-2px);
		}

		.pf-skill-icon {
			color: #d97706;
			flex-shrink: 0;
			margin-top: 3px;
		}

		.pf-project-card {
			background: #fff;
			border: 1px solid #e5e7eb;
			border-radius: 14px;
			padding: 1.75rem;
			text-decoration: none;
			transition: all 0.3s ease;
			display: flex;
			flex-direction: column;
			height: 100%;
		}
        
		.pf-project-card:hover {
			border-color: #10b981;
			box-shadow: 0 10px 20px -5px rgba(16, 185, 129, 0.1);
		}

		.pf-project-name {
			font-size: 16px;
			font-weight: 700;
			color: #111827;
			margin-bottom: 8px;
		}

		.pf-project-desc {
			font-size: 13px;
			color: #6b7280;
			line-height: 1.6;
			margin-bottom: 1.25rem;
			flex-grow: 1;
		}

		.pf-project-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
			gap: 1.5rem;
		}

		.pf-project-link {
			font-family: 'Space Mono', monospace;
			font-size: 11px;
			font-weight: 700;
			color: #10b981;
			display: flex;
			align-items: center;
			gap: 6px;
		}

		.pf-skill-text {
			font-size: 14px;
			color: #4b5563;
			line-height: 1.5;
			font-weight: 500;
		}

		/* Section Projets Associés */
		.pf-section-label {
			font-family: 'Space Mono', monospace;
			font-size: 12px;
			color: #9ca3af;
			text-transform: uppercase;
			letter-spacing: 2px;
			margin-bottom: 2rem;
			text-align: center;
			display: flex;
			align-items: center;
			gap: 15px;
		}
		.pf-section-label::before,
		.pf-section-label::after {
			content: "";
			height: 1px;
			background: #e5e7eb;
			flex: 1;
		}

		/* Style pour la zone vide ou les projets à venir */
		.pf-empty-state {
			text-align: center;
			padding: 3rem;
			background: #fdfdfd;
			border: 2px dashed #f3f4f6;
			border-radius: 16px;
			color: #9ca3af;
			font-size: 14px;
		}

		/* Back Bar */
		.pf-back-bar {
			padding: 2rem 3rem;
			border-top: 1px solid #e5e7eb;
			margin-top: 2rem;
		}
		.pf-btn-back {
			font-size: 13px;
			font-family: 'Space Mono', monospace;
			color: #6b7280;
			text-decoration: none;
			display: inline-flex;
			align-items: center;
			gap: 8px;
		}
		.pf-btn-back:hover {
			color: #d97706;
		}

		@media(max-width: 768px) {
			.pf-container {
				padding: 1.5rem;
			}
		}
	</style>
{% endblock %}

{% block body %}

	<div class="pf-page-header">
		<div class="pf-page-badge">
			<svg width="12" height="12" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
				<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
			</svg>
			Compétence 2
		</div>
		<h1 class="pf-page-title">Répondre aux
			<em>incidents</em>
			et demandes</h1>
		<p class="pf-page-sub">Analyser, diagnostiquer et résoudre les incidents tout en accompagnant les utilisateurs.</p>
	</div>

	<div class="pf-container">

		<div class="pf-grid-skills">
			{% set skills = [
            "Collecter, suivre et orienter les demandes",
            "Traiter les demandes concernant les services réseau et applicatifs",
            "Traiter les incidents liés aux services réseau et applicatifs",
            "Accompagner les utilisateurs dans la prise en main des services"
        ] %}

			{% for skill in skills %}
				<div class="pf-skill-card">
					<div class="pf-skill-icon">
						<svg width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
							<polyline points="20 6 9 17 4 12"></polyline>
						</svg>
					</div>
					<div class="pf-skill-text">{{ skill }}</div>
				</div>
			{% endfor %}
		</div>

		<div class="pf-section-label">Réalisations associées</div>

		<div class="pf-project-grid">
			<a href="{{ path('app_neptune') }}" class="pf-project-card">
				<div class="pf-project-name">Projet Neptune</div>
				<p class="pf-project-desc">Modélisation et exploitation de données structurées dans le cadre d'un développement applicatif.</p>
				<div class="pf-project-link">Voir le projet →</div>
			</a>
		</div>

	</div>

	<div class="pf-back-bar">
		<a href="{{ path('app_competences') }}" class="pf-btn-back">
			<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
				<line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
			</svg>
			Retour aux compétences
		</a>
	</div>

{% endblock %}
