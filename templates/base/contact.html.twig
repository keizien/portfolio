{% extends 'base.html.twig' %}

{% block title %}Présentation
{% endblock %}

{% block body %}

	<div class="container py-5">

		<h1 class="text-center text-primary fw-bold mb-5">
			Présentation
		</h1>

		<div class="row justify-content-center">
			<div class="col-lg-8">
				<div class="card shadow border-0 mb-4">
					<div class="card-body">

						<h3 class="text-primary fw-bold mb-3">Présentation générale</h3>

						<div class="d-flex align-items-center mb-4">
							<img src="/images/photo.jpg" alt="Photo professionnelle" class="rounded-circle shadow" style="width: 120px; height:120px; object-fit: cover;">
							<div class="ms-4">
								<p class="mb-1">
									<strong>Nom :</strong>
									BERGEAUD</p>
								<p class="mb-1">
									<strong>Prénom :</strong>
									Léo</p>
								<p class="mb-1">
									<strong>Classe :</strong>
									BTS SIO — 2ème année</p>
								<p class="mb-1">
									<strong>Option :</strong>
									SLAM</p>
								<a href="#" class="btn btn-outline-primary btn-sm mt-2">
									Télécharger mon CV
								</a>
							</div>
						</div>

						<p class="text-muted">
							Description : ...
						</p>

					</div>
				</div>

				<div class="container mt-5">
					<div class="card shadow border-0">
						<div class="card-body p-4">

							<h2 class="text-primary fw-bold mb-3">
								<i class="bi bi-mortarboard-fill"></i>
								BTS SIO – Option SLAM
							</h2>

							<p class="text-muted fs-5">
								Le BTS Services Informatiques aux Organisations (SIO) forme des professionnels capables de développer, maintenir et sécuriser des solutions informatiques pour les entreprises.
							</p>

							<h4 class="text-secondary fw-bold mt-4">Objectifs du BTS SIO</h4>
							<p class="text-muted">
								Acquérir les compétences nécessaires pour répondre aux besoins numériques des organisations : support, développement, gestion de projets, sécurité et documentation technique.
							</p>

							<h4 class="text-secondary fw-bold mt-4">Option SLAM</h4>
							<p class="text-muted">
								L’option SLAM (Solutions Logicielles et Applications Métiers) est dédiée au développement d’applications web, mobiles et logiciels internes, ainsi qu’à la gestion des bases de données.
							</p>

							<h4 class="text-secondary fw-bold mt-4">Compétences techniques visées</h4>
							<ul class="text-muted">
								<li>Développement d’applications (PHP, JS, SQL, Python…)</li>
								<li>Conception et gestion de bases de données</li>
								<li>Analyse des besoins et gestion de projets</li>
								<li>Sécurisation des applications et des données</li>
							</ul>

						</div>
					</div>
				</div>


				<div class="text-center mt-4">
					<a href="{{ path('app_accueil') }}" class="btn btn-outline-primary">
						← Retour à l'accueil
					</a>
				</div>

			</div>
		</div>

	</div>

{% endblock %}
