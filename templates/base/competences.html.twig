        <div class="pf-competence-top">
            <span class="pf-competence-code code-c3">C3</span>
            <div class="pf-competence-icon icon-c3">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0F6E56" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="2" y1="12" x2="22" y2="12"/>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
            </div>
        </div>
        <div class="pf-competence-title">Développer la présence en ligne de l'organisation</div>
        <span class="pf-competence-link link-c3">Voir la compétence <span class="arrow">→</span></span>
    </a>

    <a href="{{ path('app_travailler_mode_projet') }}" class="pf-competence-card">
        <div class="pf-competence-top">
            <span class="pf-competence-code code-c4">C4</span>
            <div class="pf-competence-icon icon-c4">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#534AB7" stroke-width="2">
                    <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                    <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
                </svg>
            </div>
        </div>
        <div class="pf-competence-title">Travailler en mode projet</div>
        <span class="pf-competence-link link-c4">Voir la compétence <span class="arrow">→</span></span>
    </a>

    <a href="{{ path('app_service_info') }}" class="pf-competence-card">
        <div class="pf-competence-top">
            <span class="pf-competence-code code-c5">C5</span>
            <div class="pf-competence-icon icon-c5">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#993C1D" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
            </div>
        </div>
        <div class="pf-competence-title">Mettre à disposition des utilisateurs un service informatique</div>
        <span class="pf-competence-link link-c5">Voir la compétence <span class="arrow">→</span></span>
    </a>

    <a href="{{ path('app_dev_pro') }}" class="pf-competence-card">
        <div class="pf-competence-top">
            <span class="pf-competence-code code-c6">C6</span>
            <div class="pf-competence-icon icon-c6">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B6D11" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
            </div>
        </div>
        <div class="pf-competence-title">Organiser son développement professionnel</div>
        <span class="pf-competence-link link-c6">Voir la compétence <span class="arrow">→</span></span>
    </a>

</div>

{% endblock %}
