            <span class="pf-competence-code code-c2">C2</span>
            <div class="pf-competence-icon icon-c2">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#854F0B" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
            </div>
        </div>
        <div class="pf-competence-title">Répondre aux incidents et aux demandes d'évolution</div>
