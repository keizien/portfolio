{% extends 'base.html.twig' %}

{% block title %}
	{{ parent() }}Compétences
{% endblock %}

{% block body %}
	<div class="container py-5">

		<h1 class="text-center text-primary display-3 fw-bold mb-4">
			<i class="bi bi-award-fill"></i>
			Compétences du BTS SIO
		</h1>

		<p class="text-center text-secondary fs-4 mb-5">
			Voici les compétences professionnelles mises en œuvre durant ma formation, mes projets et mes stages.
		</p>

		<div
			class="row g-4">

			{# --- C1 : Gérer le patrimoine informatique --- #}
			<div class="col-md-6 col-lg-4">
				<div class="card shadow border-0 h-100">
					<div class="card-body">
						<h4 class="text-primary fw-bold mb-3">
							<i class="bi bi-hdd-stack-fill"></i>
							C1 – Gérer le patrimoine informatique
						</h4>
						<a href="{{ path('app_patrimoine_info') }}" class="btn btn-primary mt-3">Voir la compétence</a>
					</div>
				</div>
			</div>

			{# --- C2 : Répondre aux incidents et demandes d’évolution --- #}
			<div class="col-md-6 col-lg-4">
				<div class="card shadow border-0 h-100">
					<div class="card-body">
						<h4 class="text-primary fw-bold mb-3">
							<i class="bi bi-life-preserver"></i>
							C2 – Répondre aux incidents et aux demandes d’évolution
						</h4>
						<a href="{{path('app_incidents')}}" class="btn btn-primary mt-3">Voir la compétence</a>
					</div>
				</div>
			</div>

			{# --- C3 : Développer la présence en ligne de l’organisation --- #}
			<div class="col-md-6 col-lg-4">
				<div class="card shadow border-0 h-100">
					<div class="card-body">
						<h4 class="text-primary fw-bold mb-3">
							<i class="bi bi-globe"></i>
							C3 – Développer la présence en ligne de l’organisation
						</h4>
						<a href="{{path('app_presence_ligne')}}" class="btn btn-primary mt-3">Voir la compétence</a>
					</div>
				</div>
			</div>

			{# --- C4 : Travailler en mode projet --- #}
			<div class="col-md-6 col-lg-4">
				<div class="card shadow border-0 h-100">
					<div class="card-body">
						<h4 class="text-primary fw-bold mb-3">
							<i class="bi bi-kanban-fill"></i>
							C4 – Travailler en mode projet
						</h4>
						<a href="{{path('app_travailler_mode_projet')}}" class="btn btn-primary mt-3">Voir la compétence</a>
					</div>
				</div>
			</div>

			{# --- C5 : Mettre à disposition des utilisateurs un service informatique --- #}
			<div class="col-md-6 col-lg-4">
				<div class="card shadow border-0 h-100">
					<div class="card-body">
						<h4 class="text-primary fw-bold mb-3">
							<i class="bi bi-people-fill"></i>
							C5 – Mettre à disposition des utilisateurs un service informatique
						</h4>
						<a href="{{path('app_service_info')}}" class="btn btn-primary mt-3">Voir la compétence</a>
					</div>
				</div>
			</div>

			{# --- C6 : Organiser son développement professionnel --- #}
			<div class="col-md-6 col-lg-4">
				<div class="card shadow border-0 h-100">
					<div class="card-body">
						<h4 class="text-primary fw-bold mb-3">
							<i class="bi bi-person-badge-fill"></i>
							C6 – Organiser son développement professionnel
						</h4>
						<a href="{{path('app_dev_pro')}}" class="btn btn-primary mt-3">Voir la compétence</a>
					</div>
				</div>
			</div>

			<a href="{{ asset('documents/competences/tableau.xlsx') }}" download class="btn btn-primary w-100">
				<i class="bi bi-download"></i>
				Télécharger le tableau des compétences
			</a>

		</div>
	</div>
{% endblock %}
