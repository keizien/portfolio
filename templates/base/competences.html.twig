{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }}Compétences
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sora', sans-serif; }

        .pf-page-header {
            padding: 3.5rem 3rem 2.5rem;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 2rem;
            flex-wrap: wrap;
        }

        .pf-page-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-family: 'Space Mono', monospace;
            font-size: 11px;
            color: #0F6E56;
            background: #E1F5EE;
            border: 1px solid #9FE1CB;
            border-radius: 100px;
            padding: 4px 14px;
            margin-bottom: 1.25rem;
        }

        .pf-page-title {
            font-size: clamp(32px, 4vw, 48px);
            font-weight: 700;
            letter-spacing: -2px;
            line-height: 1.05;
            color: #111827;
            margin: 0 0 0.75rem;
        }

        .pf-page-title em {
            font-style: normal;
            color: #1D9E75;
        }

        .pf-page-sub {
            font-size: 15px;
            color: #6b7280;
            margin: 0;
        }

        .pf-btn-download {
            background: transparent;
            color: #1D9E75;
            border: 1px solid #9FE1CB;
            border-radius: 8px;
            padding: 10px 20px;
            font-family: 'Space Mono', monospace;
            font-size: 12px;
            font-weight: 700;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            white-space: nowrap;
            transition: background 0.2s, color 0.2s;
        }

        .pf-btn-download:hover {
            background: #E1F5EE;
            color: #0F6E56;
        }

        /* Grille compétences */
        .pf-competences-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1px;
            background: #e5e7eb;
            border-top: none;
            border-bottom: 1px solid #e5e7eb;
        }

        .pf-competence-card {
            background: #fff;
            padding: 2rem;
            display: flex;
            flex-direction: column;
            text-decoration: none;
            color: inherit;
            transition: background 0.2s;
            cursor: pointer;
        }

        .pf-competence-card:hover {
            background: #f9fafb;
        }

        .pf-competence-top {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 1rem;
        }

        .pf-competence-code {
            font-family: 'Space Mono', monospace;
            font-size: 11px;
            font-weight: 700;
            border-radius: 6px;
            padding: 3px 10px;
            white-space: nowrap;
        }

        .code-c1 { color: #185FA5; background: #E6F1FB; border: 1px solid #B5D4F4; }
        .code-c2 { color: #854F0B; background: #FAEEDA; border: 1px solid #FAC775; }
        .code-c3 { color: #0F6E56; background: #E1F5EE; border: 1px solid #9FE1CB; }
        .code-c4 { color: #534AB7; background: #EEEDFE; border: 1px solid #CECBF6; }
        .code-c5 { color: #993C1D; background: #FAECE7; border: 1px solid #F5C4B3; }
        .code-c6 { color: #3B6D11; background: #EAF3DE; border: 1px solid #C0DD97; }

        .pf-competence-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .icon-c1 { background: #E6F1FB; }
        .icon-c2 { background: #FAEEDA; }
        .icon-c3 { background: #E1F5EE; }
        .icon-c4 { background: #EEEDFE; }
        .icon-c5 { background: #FAECE7; }
        .icon-c6 { background: #EAF3DE; }

        .pf-competence-title {
            font-size: 14px;
            font-weight: 600;
            color: #111827;
            margin: 0 0 1.5rem;
            line-height: 1.4;
            flex: 1;
        }

        .pf-competence-link {
            font-size: 12px;
            font-weight: 600;
            font-family: 'Space Mono', monospace;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .link-c1 { color: #185FA5; }
        .link-c2 { color: #854F0B; }
        .link-c3 { color: #0F6E56; }
        .link-c4 { color: #534AB7; }
        .link-c5 { color: #993C1D; }
        .link-c6 { color: #3B6D11; }

        .pf-competence-link .arrow {
            transition: transform 0.2s;
            display: inline-block;
        }

        .pf-competence-card:hover .pf-competence-link .arrow {
            transform: translateX(4px);
        }

        @media (max-width: 768px) {
            .pf-page-header { padding: 2rem 1.5rem; }
            .pf-competences-grid { grid-template-columns: 1fr; }
        }

        @media (min-width: 769px) and (max-width: 1024px) {
            .pf-competences-grid { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
{% endblock %}

{% block body %}

{# ── En-tête ── #}
<div class="pf-page-header">
    <div>
        <div class="pf-page-badge">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#0F6E56" stroke-width="2.5">
                <circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
            </svg>
            BTS SIO
        </div>
        <h1 class="pf-page-title"><em>Compétences</em> professionnelles</h1>
        <p class="pf-page-sub">Compétences mises en œuvre durant ma formation, mes projets et mes stages.</p>
    </div>
    <a href="{{ asset('documents/competences/tableau.xlsx') }}" download class="pf-btn-download">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Tableau .xlsx
    </a>
</div>

{# ── Grille des compétences ── #}
<div class="pf-competences-grid">

    <a href="{{ path('app_patrimoine_info') }}" class="pf-competence-card">
